# =============================================================================
# twindb-lightrag-memgraph — Environment Variables
# =============================================================================
# Copy to .env and adjust. All variables are optional with sensible defaults.

#MEMGRAPH_URI=bolt://localhost:7687
# MEMGRAPH_USERNAME=
# MEMGRAPH_PASSWORD=
# MEMGRAPH_DATABASE=memgraph

# ── Multi-tenancy ────────────────────────────────────────────────────────────
# Workspace prefix in node labels (KV_{workspace}_chunks, Vec_{workspace}_entities, etc.)
#MEMGRAPH_WORKSPACE=base

# ── Connection pools ─────────────────────────────────────────────────────────
# MEMGRAPH_POOL_SIZE=50                        # Write pool (max Bolt connections)
# MEMGRAPH_READ_POOL_SIZE=20                   # Read pool (isolated from writes)
# MEMGRAPH_WRITE_CONCURRENCY=8                 # Max concurrent write operations
# MEMGRAPH_CONNECTION_ACQUIRE_TIMEOUT=5.0      # Seconds before connection timeout

# ── Memory budget ────────────────────────────────────────────────────────────
# LightRAG-specific cap on Memgraph memory usage.
# Compared against memory_tracked (graph + vector index memory).
# 0 or unset = unlimited.
#MEMGRAPH_MEMORY_LIMIT=2GiB
#MEMGRAPH_BUDGET_ENFORCE=reject                 # off | warn | reject

# ── Vector quantization (Memgraph >= 3.8) ────────────────────────────────────
# f32 = full precision, f16 = 50% savings (default), i8 = 75% savings
#MEMGRAPH_VECTOR_SCALAR_KIND=f16

# ── Batched deletes ──────────────────────────────────────────────────────────
# Max nodes per DELETE transaction. Prevents OOM on large datasets.
# MEMGRAPH_DELETE_BATCH_SIZE=10000

# ── TTL (Memgraph Enterprise) ───────────────────────────────────────────────
# Auto-expire KV nodes after N seconds. Requires: ENABLE TTL EVERY "1d" AT "02:00:00";
# MEMGRAPH_TTL_SECONDS=2592000                 # 30 days
# MEMGRAPH_TTL_LABELS=full_docs,text_chunks    # KV namespaces that get TTL

# ── Lazy full_docs ───────────────────────────────────────────────────────────
# Purge full_docs content after PROCESSED, reconstruct from chunks on demand.
# Saves ~35-45% of storage.
# MEMGRAPH_PURGE_FULL_DOCS=on

# ── Intelligence layer (private/BNP build only) ─────────────────────────────
# TWIN_RAG_LLM_API_KEY=
# TWIN_RAG_LLM_API_BASE=
# TWIN_RAG_LLM_MODEL=gpt-oss-120b
